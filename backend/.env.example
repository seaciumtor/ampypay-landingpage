PORT=3001
ALLOWED_ORIGIN=https://seaciumtor.github.io

# SMTP — ใส่ค่าจริงก่อน deploy
SMTP_HOST=mail.eunite.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@eunite.com
SMTP_PASS=your-password-here

# email ที่รับ notification
NOTIFY_EMAIL=your-notify-email@eunite.com

# Admin login
# สร้าง hash ด้วย: node -e "const b=require('bcryptjs');console.log(b.hashSync('YOUR_PASSWORD',12))"
ADMIN_USER=admin
ADMIN_PASS_HASH=$2b$12$...

# Session secret — สุ่มใหม่ทุกครั้ง deploy: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
SESSION_SECRET=change-this-to-a-long-random-string

# TOTP secret สำหรับ Google Authenticator
# สร้างใหม่: node -e "console.log(require('speakeasy').generateSecret({length:20}).base32)"
TOTP_SECRET=YOUR_BASE32_SECRET
